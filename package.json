{
	"name": "htrncontrol",
	"displayName": "HTR NControl",
	"version": "0.4.3",
	"author": "Ahren Stevens-Taylor <ahren@mercstudio.com>, James Tan <james.tan@aims-research.com>",
	"description": "Create step-by-step documentation by recording browser interactions with screenshots",
	"type": "module",
	"license": "MIT",
	"keywords": [
		"chrome-extension",
		"react",
		"vite",
		"create-chrome-ext"
	],
	"packageManager": "bun@1.3.13",
	"engines": {
		"node": ">=14.18.0"
	},
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build && bun run cdp-bundle:build",
		"cdp-bundle:build": "vite build --config vite.cdp.config.ts",
		"preview": "vite preview",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"zip": "bun run build && bun src/zip.ts",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"postinstall:list": "bun run scripts/postinstall.ts list",
		"postinstall:run": "bun run scripts/postinstall.ts postinstall",
		"postinstall:all": "bun run scripts/postinstall.ts all",

		"firefox:dev": "vite --config firefox/vite.config.ts",
		"firefox:build": "tsc -p firefox/tsconfig.json && vite build --config firefox/vite.config.ts && vite build --config firefox/vite.content.config.ts",
		"firefox:typecheck": "tsc -p firefox/tsconfig.json --noEmit",
		"firefox:zip": "bun run firefox:build && cd firefox/build && zip -r ../htrncontrol-firefox.xpi ."
	},
	"dependencies": {
		"idb": "^8.0.3",
		"jszip": "^3.10.1",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"webextension-polyfill": "^0.12.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.13",
		"@crxjs/vite-plugin": "^2.0.0-beta.26",
		"@happy-dom/global-registrator": "^15",
		"@types/bun": "^1.3.14",
		"@types/chrome": "^0.0.246",
		"@types/firefox-webext-browser": "^143.0.0",
		"@types/gulp": "^4.0.18",
		"@types/gulp-zip": "^4.0.4",
		"@types/react": "^18.2.28",
		"@types/react-dom": "^18.2.13",
		"@types/webextension-polyfill": "^0.12.5",
		"@vitejs/plugin-react": "^4.1.0",
		"gulp": "^5.0.0",
		"gulp-zip": "^6.0.1",
		"typescript": "^5.3.3",
		"vite": "^5.1.0"
	}
}
