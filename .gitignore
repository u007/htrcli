# production
/build
/package
/firefox/build
/firefox/htrncontrol-firefox.xpi
# htrcli-dom.js is a go:embed input — it must stay committed or fresh clones
# cannot `go build` htrcli. Rebuild with: bun run cdp-bundle:build
htrcli/internal/cdp/bundle/*
!/htrcli/internal/cdp/bundle/htrcli-dom.js

